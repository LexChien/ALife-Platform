#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
APP="$ROOT_DIR/apps/gemma_web.py"

candidates=()

if [[ -x "$ROOT_DIR/.venv/bin/python" ]]; then
  candidates+=("$ROOT_DIR/.venv/bin/python")
fi

candidates+=(
  "/usr/bin/python3"
  "python3"
  "/opt/homebrew/bin/python3"
  "$HOME/.pyenv/shims/python3"
)

for candidate in "${candidates[@]}"; do
  if [[ "$candidate" != *"/"* ]]; then
    if ! command -v "$candidate" >/dev/null 2>&1; then
      continue
    fi
    candidate="$(command -v "$candidate")"
  fi

  if [[ ! -x "$candidate" ]]; then
    continue
  fi

  if "$candidate" - <<'PY' >/dev/null 2>&1
import yaml
PY
  then
    exec "$candidate" "$APP" "$@"
  fi
done

echo "No usable Python interpreter with PyYAML was found for apps/gemma_web.py." >&2
echo "Tried these candidates:" >&2
for candidate in "${candidates[@]}"; do
  echo "  $candidate" >&2
done
echo >&2
echo "On this macOS workspace, the most likely working command is:" >&2
echo "  /usr/bin/python3 apps/gemma_web.py --config configs/genai/gemma_llama_cpp.yaml --profile cpu_smoke --host 127.0.0.1 --port 8080" >&2
exit 1
